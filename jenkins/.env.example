# Copie para .env (que é ignorado pelo git) e preencha.
#   cp .env.example .env

# Credenciais do usuário admin do Jenkins (login na UI)
JENKINS_ADMIN_ID=admin
JENKINS_ADMIN_PASSWORD=troque-esta-senha

# Docker Hub — usados para criar a credencial "dockerhub-creds" automaticamente
DOCKERHUB_USER=millesdyson
DOCKERHUB_TOKEN=cole-aqui-seu-access-token-do-docker-hub

# Senhas dos demais usuários (papéis definidos no casc.yaml)
DEVELOPER_PASSWORD=troque-esta-senha    # papel "developer" (metade das permissões)
VIEWER1_PASSWORD=troque-esta-senha      # papel "ReadOnly"
VIEWER2_PASSWORD=troque-esta-senha      # papel "ReadOnly"
