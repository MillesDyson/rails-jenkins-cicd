# Copie para .env e ajuste conforme necessário (o .env é ignorado pelo git).
#
# Chave mestra para descriptografar as credentials do Rails em produção.
# Gere a partir do arquivo local (não versionado):
#   echo "RAILS_MASTER_KEY=$(cat config/master.key)" > .env
RAILS_MASTER_KEY=

# Conexão com o banco (valores padrão do docker-compose)
DATABASE_HOST=db
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
