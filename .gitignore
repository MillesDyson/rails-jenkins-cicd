# Arquivos de log e temporários
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep
/tmp/pids/*
!/tmp/pids/.keep

# Armazenamento de arquivos (uploads / SQLite)
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/.keep

# Segredos — NUNCA versionar
/config/master.key
/config/credentials/*.key
/.env*
!/.env.example
# .env de qualquer subpasta (ex.: jenkins/.env com o token do Docker Hub)
**/.env

# Artefatos de teste e cobertura
/coverage/
/spec/examples.txt
/tmp/rspec.xml

# Cache do bundler / bootsnap
/.bundle
